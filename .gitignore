# =========================================================
# Node / JavaScript (frontend)
# =========================================================
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*
*.tsbuildinfo

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native build output (regenerated by `expo prebuild` / EAS)
/ios
/android
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro bundler
.metro-health-check*

# =========================================================
# Python (backend)
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# =========================================================
# Environment variables / secrets - NEVER commit real values
# =========================================================
.env
.env.*
!.env.example
*.pem
*credentials*.json

# =========================================================
# App-specific sensitive / generated data - not source code,
# doesn't belong in git regardless of whether it's "in use"
# =========================================================
users.json
*_cache.json
category_cache.json
merchants.json
merchantsBackup.json
personal_caches/
backup.json
*.csv
*.xlsx
*.xls
*statement*.pdf
*Statement*.pdf

# =========================================================
# Editor / IDE
# =========================================================
.vscode/
.idea/
*.swp
*.swo

# =========================================================
# OS noise
# =========================================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# Logs
# =========================================================
*.log
logs/